package com.example.csvtosql.Service;
 
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.opencsv.CSVParserBuilder;
import com.opencsv.CSVReader;
import com.opencsv.CSVReaderBuilder;

import java.io.InputStreamReader;
 
@Service
public class CsvService {
 
    @Autowired
    private JdbcTemplate jdbcTemplate;
 
    public String processCSV(MultipartFile file) {
        try {
        	CSVReader csvReader = new CSVReaderBuilder(
        	        new InputStreamReader(file.getInputStream())
        	)
        	.withCSVParser(
        	        new CSVParserBuilder()
        	                .withSeparator(',')
        	                .withQuoteChar('\"')
        	                .build()
        	)
        	.build();
        	 
 
            // 1. HEADER
            String[] columns = csvReader.readNext();
            if (columns == null) return "Empty CSV file";
 
            String tableName = "generated_table";
 
            // 2. CLEAN COLUMN NAMES
            String[] cleanColumns = new String[columns.length];
            for (int i = 0; i < columns.length; i++) {
                String col = columns[i].trim()
                        .toLowerCase()
                        .replaceAll("[^a-z0-9]", "_");
 
                col = "col_" + col; // avoid SQL keywords
                cleanColumns[i] = col;
            }
 
            // 3. FIRST DATA ROW
            String[] firstValues = csvReader.readNext();
            if (firstValues == null) return "No data found";
 
            // 4. DETECT DATA TYPES
            String[] types = new String[firstValues.length];
            for (int i = 0; i < firstValues.length; i++) {
                String val = firstValues[i].trim();
 
                if (val.matches("\\d+")) {
                    types[i] = "INT";
                } else if (val.matches("\\d+\\.\\d+")) {
                    types[i] = "DOUBLE";
                } else {
                    types[i] = "VARCHAR(255)";
                }
            }
 
            // 5. DROP TABLE
            jdbcTemplate.execute("DROP TABLE IF EXISTS " + tableName);
 
            // 6. CREATE TABLE
            StringBuilder createQuery = new StringBuilder("CREATE TABLE " + tableName + " (");
            for (int i = 0; i < cleanColumns.length; i++) {
                createQuery.append(cleanColumns[i])
                        .append(" ")
                        .append(types[i])
                        .append(",");
            }
            createQuery.deleteCharAt(createQuery.length() - 1);
            createQuery.append(")");
 
            jdbcTemplate.execute(createQuery.toString());
 
            // 7. INSERT FIRST ROW
            insertRow(tableName, firstValues);
 
            // 8. INSERT REMAINING ROWS
            String[] row;
            while ((row = csvReader.readNext()) != null) {
                insertRow(tableName, row);
            }
 
            return "Table created and data inserted successfully";
 
        } catch (Exception e) {
            return "Error: " + e.getMessage();
        }
    }
 
    // INSERT METHOD
    private void insertRow(String table, String[] values) {
    	 
        StringBuilder sql = new StringBuilder("INSERT INTO " + table + " VALUES (");
     
        // create ?,?,? placeholders
        for (int i = 0; i < values.length; i++) {
            sql.append("?,");
        }
        sql.deleteCharAt(sql.length() - 1);
        sql.append(")");
     
        // prepare values array
        Object[] params = new Object[values.length];
     
        for (int i = 0; i < values.length; i++) {
            String val = values[i];
     
            if (val == null || val.trim().isEmpty()) {
                params[i] = null;
            } else if (val.matches("\\d+")) {
                params[i] = Integer.parseInt(val);
            } else if (val.matches("\\d+\\.\\d+")) {
                params[i] = Double.parseDouble(val);
            } else {
                params[i] = val; // no need to handle quotes manually
            }
        }
     
        jdbcTemplate.update(sql.toString(), params);
    }
     
}
 